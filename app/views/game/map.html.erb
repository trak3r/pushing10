<% if notice %><div class="flash flash-notice"><%= notice %></div><% end %>
<% if alert %><div class="flash flash-alert"><%= alert %></div><% end %>

<% now = Time.current %>
<% flights_json = @active_flights.map { |f|
  from = f.from_airport
  to = f.to_airport
  progress = flight_progress(f)
  elapsed = f.departed_at ? (now - f.departed_at).to_f : 0.0
  fx = map_x(from.longitude); fy = map_y(from.latitude)
  tx = map_x(to.longitude); ty = map_y(to.latitude)
  dx = tx - fx; dy = ty - fy
  dist = Math.sqrt(dx * dx + dy * dy)
  nx = -dy / dist; ny = dx / dist
  arc = dist * 0.4
  cx = (fx + tx) / 2 + nx * arc; cy = (fy + ty) / 2 + ny * arc
  pos = arc_point(from.latitude, from.longitude, to.latitude, to.longitude, progress)
  {
    id: f.id,
    plane: f.plane.name,
    from_code: from.code,
    to_code: to.code,
    fx: fx.round(1), fy: fy.round(1),
    tx: tx.round(1), ty: ty.round(1),
    cx: cx.round(1), cy: cy.round(1),
    elapsed: elapsed.round(1),
    duration: f.duration_seconds,
    x: pos[:x], y: pos[:y], angle: pos[:angle],
  }
} %>

<div class="map-container"
     data-controller="map"
     data-map-flights-value="<%= flights_json.to_json %>">
  <svg viewBox="0 0 <%= @map_w + 40 %> <%= @map_h + 40 %>" class="map-svg">
    <rect x="0" y="0" width="<%= @map_w + 40 %>" height="<%= @map_h + 40 %>" fill="var(--bg)" rx="12"/>

    <defs>
      <radialGradient id="airport-glow" cx="50%" cy="50%" r="50%">
        <stop offset="0%" stop-color="var(--accent2)" stop-opacity="0.4"/>
        <stop offset="100%" stop-color="var(--accent2)" stop-opacity="0"/>
      </radialGradient>
    </defs>

    <% @airports.each do |a| %>
      <% ax = map_x(a.longitude); ay = map_y(a.latitude) %>
      <circle cx="<%= ax %>" cy="<%= ay %>" r="18" fill="url(#airport-glow)"/>
      <circle cx="<%= ax %>" cy="<%= ay %>" r="5" fill="var(--accent2)" stroke="var(--bg)" stroke-width="2"/>
      <text x="<%= ax %>" y="<%= ay + 16 %>" text-anchor="middle" fill="var(--text2)" font-size="9" font-weight="600" font-family="system-ui"><%= a.code %></text>
    <% end %>

    <% @active_flights.each do |f| %>
      <% from = f.from_airport; to = f.to_airport %>
      <path d="<%= arc_path(from.latitude, from.longitude, to.latitude, to.longitude) %>"
            fill="none" stroke="var(--accent)" stroke-width="1.5" stroke-opacity="0.4"
            stroke-dasharray="4 3"/>
    <% end %>

    <% flights_json.each do |fj| %>
      <g class="plane-marker" data-flight-id="<%= fj[:id] %>"
         transform="translate(<%= fj[:x] %>, <%= fj[:y] %>) rotate(<%= fj[:angle] %>)">
        <%= pixel_art :plane_small, size: 3 %>
      </g>
    <% end %>
  </svg>

  <% if @active_flights.any? %>
    <div class="map-legend">
      <% @active_flights.each do |f| %>
        <% fj = flights_json.find { |j| j[:id] == f.id } %>
        <div class="map-legend-item" data-flight-id="<%= f.id %>">
          <span class="legend-route text-sm"><%= f.from_airport.code %> &rarr; <%= f.to_airport.code %></span>
          <span class="legend-plane text-sm text-muted"><%= f.plane.name %></span>
          <span class="legend-eta text-sm text-accent"><%= f.seconds_remaining %>s</span>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="map-empty">
      <p class="text-muted text-sm">No flights in the air right now</p>
    </div>
  <% end %>
</div>
