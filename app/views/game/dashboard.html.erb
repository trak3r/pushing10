<% if notice %><div class="flash flash-notice"><%= notice %></div><% end %>
<% if alert %><div class="flash flash-alert"><%= alert %></div><% end %>

<div class="header">
  <%= icon :plane, size: 28 %>
  <span class="title">PUSHING <span class="title-10">10</span></span>
</div>

<div class="status-bar">
  <div class="status-item">
    <div class="status-label">Coins</div>
    <div class="status-value text-accent"><%= icon :coin %>&nbsp;<%= @player.coins %></div>
  </div>
  <div class="status-item">
    <div class="status-label">Planes</div>
    <div class="status-value"><%= icon :plane, size: 16 %>&nbsp;<%= @planes.count %></div>
  </div>
  <div class="status-item">
    <div class="status-label">In Air</div>
    <div class="status-value"><%= @planes.count(&:in_flight?) %></div>
  </div>
  <div class="status-item">
    <div class="status-label">Flights</div>
    <div class="status-value"><%= Flight.where(plane: @planes).arrived.count %></div>
  </div>
</div>

<div class="fleet">
  <% @planes.each do |p| %>
    <% active = p == @plane %>
    <a href="?plane_id=<%= p.id %>" class="plane-card<%= ' active' if active %><%= ' in-flight' if p.in_flight? %>">
      <div class="plane-card-header">
        <%= icon :plane, size: 16 %>
        <strong><%= p.name %></strong>
        <span class="status-badge <%= p.in_flight? ? 'flying' : 'landed' %>"><%= p.status_text %></span>
      </div>
      <div class="plane-card-body">
        <span class="text-muted"><%= p.status_direction %></span>
        <% if p.in_flight? %>
          <span class="text-sm text-accent"><%= p.active_flight.seconds_remaining %>s</span>
        <% else %>
          <span class="text-sm text-muted"><%= p.boarded_passengers.count %>/<%= p.capacity %> seats</span>
        <% end %>
      </div>
    </a>
  <% end %>
</div>

<% if @active_flight %>
  <div class="card" style="border-color: var(--accent); text-align: center;">
    <h2 style="color: var(--accent); margin-bottom: 8px;">EN ROUTE</h2>
    <p class="text-lg">
      <%= @active_flight.from_airport.code %> &rarr; <%= @active_flight.to_airport.code %>
    </p>
    <p class="text-muted mt-sm">
      <%= @active_flight.distance %>km &middot; Arriving in
      <span id="eta-countdown"><%= @seconds_remaining %>s</span>
    </p>
    <progress id="eta-progress" value="<%= @active_flight.duration_seconds - @seconds_remaining %>" max="<%= @active_flight.duration_seconds %>" style="width: 100%; height: 8px; border-radius: 4px; margin-top: 8px;"></progress>
  </div>

  <script>
  (function() {
    var remaining = <%= @seconds_remaining %>;
    var total = <%= @active_flight.duration_seconds %>;
    var planeId = <%= @plane.id %>;
    if (remaining <= 0) return;
    var countdown = document.getElementById('eta-countdown');
    var progress = document.getElementById('eta-progress');
    var interval = setInterval(function() {
      remaining--;
      if (remaining <= 0) {
        clearInterval(interval);
        window.location.href = '/?plane_id=' + planeId;
      } else {
        countdown.textContent = remaining + 's';
        if (progress) progress.value = total - remaining;
      }
    }, 1000);
  })();
</script>

<% else %>
  <div class="card">
    <div class="row mb-sm">
      <h2><%= icon :airport, size: 20 %>&nbsp;<%= @current_airport.name %></h2>
      <span class="tag"><%= @current_airport.code %></span>
    </div>
    <p class="text-muted"><%= @plane.name %> &middot; <%= @plane.range %>km range &middot; <%= @plane.speed %>km/h &middot; <%= @boarded_passengers.count %>/<%= @plane.capacity %> seats</p>
  </div>

  <h3>Passengers</h3>
  <div class="passenger-list mt-sm mb-sm">
    <% if @airport_passengers.any? %>
      <% @airport_passengers.each do |entry| %>
          <% pax = entry[:passenger] %>
        <% case entry[:status] %>
        <% when :boarded %>
          <div class="passenger-item boarded">
            <div class="passenger-info">
              <%= icon :passenger, size: 16 %> <strong><%= pax.name %></strong>
              <span class="text-muted text-sm">&rarr; <%= pax.destination_airport.code %> &middot; <%= pax.reward %> coins &middot; <span class="text-accent">onboard</span></span>
            </div>
            <%= button_to "Deplane", unboard_passenger_path(pax, plane_id: @plane.id), method: :post, class: "btn btn-sm btn-outline" %>
          </div>
        <% when :taken %>
          <div class="passenger-item taken">
            <div class="passenger-info">
              <%= icon :passenger, size: 16 %> <strong><%= pax.name %></strong>
              <span class="text-muted text-sm">&rarr; <%= pax.destination_airport.code %> &middot; <%= pax.reward %> coins &middot; on another plane</span>
            </div>
            <span class="btn btn-sm btn-outline disabled">In use</span>
          </div>
        <% else %>
          <div class="passenger-item">
            <div class="passenger-info">
              <%= icon :passenger, size: 16 %> <strong><%= pax.name %></strong>
              <span class="text-muted text-sm">&rarr; <%= pax.destination_airport.code %> &middot; <%= pax.reward %> coins</span>
            </div>
            <% if @plane_full %>
              <span class="btn btn-sm btn-outline disabled">Full</span>
            <% else %>
              <%= button_to "Board", board_passenger_path(pax, plane_id: @plane.id), method: :post, class: "btn btn-sm btn-primary" %>
            <% end %>
          </div>
        <% end %>
      <% end %>
    <% else %>
      <p class="text-muted">No passengers here right now.</p>
    <% end %>
  </div>

  <h3>Destinations</h3>
  <div class="dest-grid mt-sm">
    <% @destinations.each do |d| %>
      <div class="dest-item<%= ' out-of-range' unless d[:in_range] %>">
        <div class="col">
          <strong><%= d[:airport].code %> &ndash; <%= d[:airport].name %></strong>
          <span class="text-muted text-sm">
            <%= d[:distance] %>km &middot; Fuel <%= d[:fuel_cost] %>c
            <% if d[:deliverable_count] > 0 %>
              &middot; Pax <%= d[:pax_revenue] %>c
              <span class="<%= d[:net] >= 0 ? 'text-accent' : 'text-muted' %>"><%= d[:net] >= 0 ? '+' : '' %><%= d[:net] %>c</span>
            <% else %>
              &middot; <span class="text-muted">no pax</span>
            <% end %>
            <%= "&middot; OUT OF RANGE".html_safe unless d[:in_range] %>
          </span>
        </div>
        <% if d[:in_range] %>
          <%= button_to "Fly", { action: "do_fly" }, params: { destination_id: d[:airport].id, plane_id: @plane.id }, method: :post, class: "btn btn-sm btn-primary" %>
        <% end %>
      </div>
    <% end %>
  </div>
<% end %>
