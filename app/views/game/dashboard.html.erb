<% if notice %><div class="flash flash-notice"><%= notice %></div><% end %>
<% if alert %><div class="flash flash-alert"><%= alert %></div><% end %>

<div class="status-bar">
  <div class="status-item">
    <div class="status-label">Coins</div>
    <div class="status-value text-accent"><%= @player.coins %></div>
  </div>
  <div class="status-item">
    <div class="status-label">Location</div>
    <div class="status-value"><%= @current_airport.code %></div>
  </div>
  <div class="status-item">
    <div class="status-label">Plane</div>
    <div class="status-value"><%= @plane.name %></div>
  </div>
  <div class="status-item">
    <div class="status-label">Capacity</div>
    <div class="status-value"><%= @boarded_passengers.count %>/<%= @plane.capacity %></div>
  </div>
</div>

<% if @active_flight %>
  <div class="card" style="border-color: var(--accent); text-align: center;">
    <h2 style="color: var(--accent); margin-bottom: 8px;">EN ROUTE</h2>
    <p class="text-lg">
      <%= @active_flight.from_airport.code %> &rarr; <%= @active_flight.to_airport.code %>
    </p>
    <p class="text-muted mt-sm">
      <%= @active_flight.distance %>km &middot; Arriving in
      <span id="eta-countdown" data-seconds="<%= @seconds_remaining %>">
        <%= @seconds_remaining %>s
      </span>
    </p>
    <progress value="<%= @active_flight.duration_seconds - @seconds_remaining %>" max="<%= @active_flight.duration_seconds %>" style="width: 100%; height: 8px; border-radius: 4px; margin-top: 8px;"></progress>
    <p class="text-muted text-sm mt-sm">Refresh to check arrival status.</p>
  </div>

  <script>
  (function() {
    var el = document.getElementById('eta-countdown');
    if (!el) return;
    var remaining = parseInt(el.dataset.seconds);
    if (remaining <= 0) return;
    var interval = setInterval(function() {
      remaining--;
      if (remaining <= 0) {
        clearInterval(interval);
        el.textContent = '0s';
        location.reload();
      } else {
        el.textContent = remaining + 's';
      }
    }, 1000);
  })();
</script>

<% else %>
  <div class="card">
    <div class="row mb-sm">
      <h2><%= @current_airport.name %></h2>
      <span class="tag"><%= @current_airport.code %></span>
    </div>
    <p class="text-muted"><%= @plane.name %> &middot; <%= @plane.range %>km range &middot; <%= @plane.speed %>km/h</p>
  </div>

  <% if @boarded_passengers.any? %>
    <h3>Boarded Passengers</h3>
    <div class="passenger-list mt-sm mb-sm">
      <% @boarded_passengers.each do |p| %>
        <div class="passenger-item">
          <div class="passenger-info">
            <strong><%= p.name %></strong>
            <span class="text-muted text-sm"><%= p.origin_airport.code %> &rarr; <%= p.destination_airport.code %> (<%= p.reward %> coins)</span>
          </div>
          <%= button_to "Unboard", unboard_passenger_path(p), method: :post, class: "btn btn-sm btn-danger" %>
        </div>
      <% end %>
    </div>
  <% end %>

  <h3>Available Passengers</h3>
  <div class="passenger-list mt-sm mb-sm">
    <% if @available_passengers.any? %>
      <% @available_passengers.each do |p| %>
        <div class="passenger-item">
          <div class="passenger-info">
            <strong><%= p.name %></strong>
            <span class="text-muted text-sm"><%= p.destination_airport.code %> &middot; <%= p.reward %> coins</span>
          </div>
          <%= button_to "Board", board_passenger_path(p), method: :post, class: "btn btn-sm btn-primary" %>
        </div>
      <% end %>
    <% else %>
      <p class="text-muted">No passengers here right now.</p>
    <% end %>
  </div>

  <h3>Destinations</h3>
  <div class="dest-grid mt-sm">
    <% @destinations.each do |d| %>
      <div class="dest-item<%= ' out-of-range' unless d[:in_range] %>">
        <div class="col">
          <strong><%= d[:airport].code %> &ndash; <%= d[:airport].name %></strong>
          <span class="text-muted text-sm">
            <%= d[:distance] %>km
            <% if d[:deliverable_passengers] > 0 %>
              &middot; <%= d[:deliverable_passengers] %> deliverable
            <% end %>
            <%= "&middot; OUT OF RANGE".html_safe unless d[:in_range] %>
          </span>
        </div>
        <% if d[:in_range] %>
          <%= button_to "Fly", { action: "do_fly" }, params: { destination_id: d[:airport].id }, method: :post, class: "btn btn-sm btn-primary" %>
        <% end %>
      </div>
    <% end %>
  </div>
<% end %>
